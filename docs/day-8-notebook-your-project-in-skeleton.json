n":[{"type":"code","lang":"python","executable":true,"value":"# --- Starter D: collation / variants (Day 2) — delete if not yours ---\n# Line up two short witnesses of the same line and find where they disagree.\nimport difflib\nwitness_1 = \"And palmeres for to seken straunge strondes\".split()\nwitness_2 = \"And palmers for to seke straunge londes\".split()\n\nsm = difflib.SequenceMatcher(a=witness_1, b=witness_2)\nprint(\"agreement:\", round(sm.ratio()*100), \"%\")\nfor tag, i1, i2, j1, j2 in sm.get_opcodes():\n    if tag != \"equal\":\n        print(f\"  {tag:9s} {' '.join(witness_1[i1:i2]) or '_':<20} <> {' '.join(witness_2[j1:j2]) or '_'}\")","key":"zy2eR98bxl"},{"type":"outputs","id":"tkCS9QsjsZ0FRUZDu-K2_","children":[],"key":"O8Ch8IZVsf"}],"key":"GQdh5hDICM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# --- Starter E: feature similarity (Day 4 & 7) — delete if not yours ---\n# Three toy \"shapes\" as feature vectors; how alike is each pair?\nimport numpy as np\nfrom sklearn.metrics.pairwise import cosine_similarity\n\nlabels = [\"sign_A\", \"sign_B\", \"sign_C\"]\nX = np.array([\n    [1.0, 0.2, 0.9],   # sign_A\n    [0.9, 0.3, 0.8],   # sign_B (close to A)\n    [0.1, 1.0, 0.2],   # sign_C (different)\n])\nsim = cosine_similarity(X)\nfor i, row in enumerate(labels):\n    print(row, {labels[j]: round(float(sim[i][j]), 2) for j in range(len(labels))})","key":"Hj6MTK8UZE"},{"type":"outputs","id":"nNsooCad6rYsc3Y6NsRPg","children":[],"key":"DaT4YxCSju"}],"key":"caFdQY1APj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# --- Starter F: projection / clustering (Day 7) — delete if not yours ---\n# Squash many features down to 2-D so you can plot items you can't eyeball.\nimport numpy as np\nfrom sklearn.decomposition import PCA\n\nlabels = [\"item1\", \"item2\", \"item3\", \"item4\"]\nX = np.array([\n    [1.0, 0.2, 0.9, 0.1],\n    [0.9, 0.3, 0.8, 0.2],\n    [0.1, 1.0, 0.2, 0.9],\n    [0.2, 0.9, 0.1, 1.0],\n])\nxy = PCA(n_components=2).fit_transform(X)\nfor lab, (x, y) in zip(labels, xy):\n    print(f\"{lab}: ({x:+.2f}, {y:+.2f})\")\n# Plot it (Day 7 style):\n# import matplotlib.pyplot as plt\n# plt.scatter(xy[:,0], xy[:,1])\n# for lab,(x,y) in zip(labels, xy): plt.annotate(lab, (x,y))\n# plt.show()","key":"gZb8KcIVjD"},{"type":"outputs","id":"V2WCh-7H2itN7G_s4iF8X","children":[],"key":"yBcjcDtIty"}],"key":"qDDv7JDfBF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# --- Starter G: formants / sound (Day 5) — delete if not yours ---\n# Two vowels as (F1, F2) points in the vowel space; how far apart are they?\nimport math\nvowel_old = (450, 1700)   # F1, F2 in Hz  (before a shift)\nvowel_new = (350, 2100)   # F1, F2 in Hz  (after a shift)\n\ndist = math.dist(vowel_old, vowel_new)\nprint(\"vowel-space distance:\", round(dist), \"Hz\")\nprint(\"F1 moved\", vowel_new[0]-vowel_old[0], \"Hz; F2 moved\", vowel_new[1]-vowel_old[1], \"Hz\")","key":"IZ6SdtbNIc"},{"type":"outputs","id":"-xfX-t_CZqXpSUuRYaADH","children":[],"key":"Img6XW86GV"}],"key":"qmtY3BiU2P"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"3. My first picture","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tXuLFh3CYp"}],"identifier":"id-3-my-first-picture","label":"3. My first picture","html_id":"id-3-my-first-picture","implicit":true,"key":"u5OYkbYFK1"},{"type":"blockquote","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"🔧 ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"CbCBvNFMC0"},{"type":"emphasis","position":{"star